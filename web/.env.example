# Environment variables for do-web-doc-resolver UI
# Copy this file to .env.local and fill in values

# App URL (used for absolute links and OG images)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: API endpoint for the resolver backend
NEXT_PUBLIC_RESOLVER_URL=http://localhost:8000

# Provider API Keys (optional - free providers work without keys)
# Mark these as "Sensitive" in Vercel dashboard for security
EXA_API_KEY=
TAVILY_API_KEY=
SERPER_API_KEY=
FIRECRAWL_API_KEY=
MISTRAL_API_KEY=

# Optional: Max characters in response (default: 8000)
WEB_RESOLVER_MAX_CHARS=8000

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_ANALYTICS_ID=